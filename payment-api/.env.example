# Server
PORT=3000

# Razorpay (never commit real secrets)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
# Alias supported by server:
# RAZORPAY_KEY_SECRET=

# Firebase Admin — paste full service account JSON as ONE line in Railway/Render
# (same project as your app — needed to verify ID tokens + write subscriptions)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: comma-separated origin list. Leave empty to allow dynamic origins (good for React Native).
# CORS_ORIGINS=https://your-web-app.com,http://localhost:8081
