# Server
PORT=3000

# Razorpay (never commit real secrets)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
# Alias supported by server:
# RAZORPAY_KEY_SECRET=

# Razorpay Orders API currency is fixed to GBP in server.js (UK £ / pence).
# Enable GBP on your Razorpay dashboard for this account — the mobile app only shows £.

# Firebase Admin — choose ONE (Railway: use A).

# A) Production / Railway: paste full service account JSON as ONE line (recommended).
#    If auth fails after deploy, check private_key newlines: JSON must use \n inside the PEM string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: log loudly if JSON project_id differs (e.g. FIREBASE_EXPECT_PROJECT_ID=routingapp-4bcb4)
# FIREBASE_EXPECT_PROJECT_ID=routingapp-4bcb4

# B) Local dev: path to the downloaded JSON file (never commit that file)
# GOOGLE_APPLICATION_CREDENTIALS=./routingapp-firebase-adminsdk-xxxxx.json

# C) Optional fallback only if A and B are unset (not needed when FIREBASE_SERVICE_ACCOUNT_JSON is set):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Optional: comma-separated origin list. Leave empty to allow dynamic origins (good for React Native).
# CORS_ORIGINS=https://your-web-app.com,http://localhost:8081
