# Copy to functions/.env for local emulator (never commit .env)
RAZORPAY_KEY_ID=rzp_test_your_key_id

# Key secret from Razorpay Dashboard → API Keys (same value whether you name it SECRET or KEY_SECRET)
RAZORPAY_SECRET=your_razorpay_key_secret

# Optional alias — if set, used when RAZORPAY_SECRET is empty
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
